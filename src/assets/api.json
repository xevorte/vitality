      "get": {
        "tags": [
          "Daily Nutrition"
        ],
        "summary": "Get Nutrition",
        "description": "Get daily nutrition data.\n\n- Single date: provide `target_date`\n- Date range: provide `start_date` and `end_date`\n- Filter by category: provide `category`\n\nHeader: Authorization: Bearer <session_token>",
        "operationId": "get_nutrition_daily_nutritions__get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "target_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Single date (YYYY-MM-DD)",
              "title": "Target Date"
            },
            "description": "Single date (YYYY-MM-DD)"
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Start date for range (YYYY-MM-DD)",
              "title": "Start Date"
            },
            "description": "Start date for range (YYYY-MM-DD)"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "End date for range (YYYY-MM-DD)",
              "title": "End Date"
            },
            "description": "End date for range (YYYY-MM-DD)"
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter: breakfast | lunch | dinner",
              "title": "Category"
            },
            "description": "Filter: breakfast | lunch | dinner"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
