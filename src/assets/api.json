    "/daily-nutritions/": {
      "post": {
        "tags": [
          "Daily Nutrition"
        ],
        "summary": "Insert Nutrition",
        "description": "Insert a daily nutrition entry with optional food image.\n\n- Send as **multipart/form-data**\n- `nutrition` field is a JSON string\n- `food_image` is optional file upload\n\nHeader: Authorization: Bearer <session_token>",
        "operationId": "insert_nutrition_daily_nutritions__post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_insert_nutrition_daily_nutritions__post"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
